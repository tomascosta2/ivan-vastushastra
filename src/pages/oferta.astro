        </a>
      </div>
    </div>
  </footer>

  <script is:inline>
    /* Marquee */
    /* (handled by CSS animation) */

    /* FAQ Accordion */
    (function () {
      document.querySelectorAll(".oferta-faq-item").forEach(function (item) {
        var btn = item.querySelector(".oferta-faq-question");
        var answer = item.querySelector(".oferta-faq-answer");
        btn.addEventListener("click", function () {
          var isOpen = item.classList.contains("open");
          document.querySelectorAll(".oferta-faq-item.open").forEach(function (o) {
            o.classList.remove("open");
            o.querySelector(".oferta-faq-answer").style.maxHeight = "0";
          });
          if (!isOpen) {
            item.classList.add("open");
            answer.style.maxHeight = answer.scrollHeight + "px";
          }
        });
      });
    })();
  </script>

  <script is:inline>
    window.addEventListener("load", function () {
      if (typeof fbq !== "undefined") fbq("track", "PageView");
    });
  </script>
</Layout>

<style>
  #grain-oferta {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px 180px;
  }

  .marquee-track-oferta {
    animation: marquee-oferta 30s linear infinite;
  }
  @keyframes marquee-oferta {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }

  .oferta-faq-item.open .oferta-faq-icon svg {
    transform: rotate(45deg);
  }
  .oferta-faq-item.open .oferta-faq-icon {
    background-color: rgba(243, 178, 58, 0.1);
    border-color: #c4a55a;
  }
</style>
