---
import Layout from "../layouts/Layout.astro";

const CTA_URL = "https://pay.hotmart.com/M104321896G?off=ruis2d2o&hotfeature=51";

const MODULOS = [
  {
    num: "01",
    title: "¿Qué es el Vastu Shastra? Orígenes en India",
    hook: "¿Y si tu Casa tuviera que ver con el estrés en tu Vida?",
    desc: "En esta clase vas a descubrir qué es el Vastu Shastra, de dónde surge y por qué esta Ciencia Milenaria sigue vigente hoy. Comprenderás cómo la relación entre tus espacios, la Naturaleza y tu energía personal puede estar influyendo silenciosamente en tu vida.",
    dur: "~30 min",
  },
  {
    num: "02",
    title: "El Alma del Espacio — Vastu Purusha",
    hook: "La energía no se ve, pero se siente.",
    desc: "En esta clase vas a entender cómo funciona el campo energético en vos y en tus espacios a través del Vastu Purusha, y así comprender por qué algunos lugares te expanden y otros te drenan. Vas a descubrir las fuentes de energía que alimentan tu hogar y cómo interactúan con tu propio estado interior.",
    dur: "~30 min",
  },
  {
    num: "03",
    title: "El Mapa Energético para crear Armonía",
    hook: "Cada espacio tiene su lenguaje.",
    desc: "En esta clase vas a aprender a leerlo. Exploraremos los cinco elementos, las orientaciones y el mapa energético que impacta directamente en tu salud, trabajo, relaciones y abundancia. Vas a identificar desequilibrios concretos y comprender qué mensajes está reflejando tu espacio sobre tu vida.",
    dur: "~30 min",
  },
  {
    num: "04",
    title: "Tecnología Ancestral + Formación en Vastu",
    hook: "No alcanza con entender: hay que habitar conscientemente.",
    desc: "En esta clase vas a conocer técnicas simples y aplicables para limpiar, armonizar y desbloquear tu hogar, transformando estrés en bienestar. Además, descubrirás cómo seguir profundizando en el Vastu Shastra si sentís el llamado de formarte y ayudar a otros a transformar sus espacios.",
    dur: "~30 min",
  },
];

const BONUS = [
  {
    num: "B1",
    title: "¿Cómo armar un Altar en mi Casa?",
    desc: "Aprende a crear un punto de energía consciente en tu hogar usando los principios del Vastu.",
  },
  {
    num: "B2",
    title: "Líneas Hartmann — ¿Cómo detectarlas?",
    desc: "Descubre las redes de energía geopática que atraviesan tu espacio y cómo identificarlas.",
  },
  {
    num: "B3",
    title: "Meditación de los 5 Elementos",
    desc: "Una práctica guiada para conectar con Tierra, Agua, Fuego, Aire y Éter en tu espacio.",
  },
];

const TESTIMONIOS = [
  {
    nombre: "Emilia Cuervo",
    rol: "Arquitecta",
    texto: "Me encantó el curso introductorio de Vastu Shastra! Iván es muy claro y didáctico con sus explicaciones. Ahora me encuentro realizando la formación ya que necesitaba aprender en profundidad este tema que me resulta muy interesante y aplicable en el día a día. Lo recomiendo 100%.",
    image: "/images/FERNANDA-MARCÓ-DE-PONT.jpeg",
  },
  {
    nombre: "María Belén López",
    rol: "Alumna del curso",
    texto: "Me sentí muy a gusto durante la clase. Los temas tratados fueron más de los que esperaba, me sorprendió y colmó mis expectativas respecto al contenido. Logra bajar a todos los niveles de entendimiento el contenido que busca transmitir. Me agradan su simpleza y sus modos.",
    image: "/images/LUCÍA-DELLEA.jpg",
  },
  {
    nombre: "Victoria Rodriguez",
    rol: "Alumna del curso",
    texto: "El curso espectacular, igual que la forma en que nos enseña Iván con palabras sencillas, ejemplos prácticos de aplicación. Aplicaré los conceptos en mi hogar y espero compartir mi experiencia.",
    image: "/images/CECILIA-RAMADORI.jpeg",
  },
  {
    nombre: "Natalia Rathmann",
    rol: "Alumna del curso",
    texto: "Me encantó el curso; siento que recibimos información de valor y muy completa para llevar a la práctica inmediatamente. Iván me trasmitió claridad, precisión e inspiración. Voy por la formación! Muchas gracias!",
    image: "/images/AGUSTINA-VANZULLI.jpg",
  },
];

const FAQS = [
  {
    pregunta: "¿Necesito tener conocimientos previos o ser Arquitecto?",
    respuesta: "No. El curso está diseñado desde cero para que cualquier persona pueda aprender los principios del Vastu Shastra, sin importar su profesión o experiencia previa.",
  },
  {
    pregunta: "¿Qué formato tienen las clases?",
    respuesta: "El curso es 100% online y grabado, para que lo hagas a tu ritmo. Incluye 4 módulos de aproximadamente 30 minutos cada uno, más 3 bonus especiales y una sorpresa final para quienes lleguen hasta el final.",
  },
  {
    pregunta: "¿Puedo trabajar como Consultor después del Curso?",
    respuesta: "Este es un curso introductorio que te brinda las bases esenciales del Vastu Shastra. Es el primer paso para comprender esta Ciencia Ancestral y decidir si querés profundizar profesionalmente. Al finalizar, vas a recibir un regalo especial para continuar tu formación.",
  },
  {
    pregunta: "¿Cómo accedo al curso después de comprar?",
    respuesta: "Recibirás el acceso por email de forma inmediata. Podés ingresar desde cualquier dispositivo (computadora, smartphone o tablet) a través de la plataforma Hotmart.",
  },
  {
    pregunta: "¿Cómo compro y comienzo?",
    respuesta: "Hacé clic en 'Comprar ahora', completá los datos y accedé inmediatamente. Lo único que necesitás es conexión a internet, un dispositivo y el deseo genuino de empezar a diseñar bienestar desde tu propio espacio.",
  },
];

const MARQUEE_ITEMS = [
  "4 Módulos completos",
  "100% Online y grabado",
  "3 Bonus especiales",
  "Acceso permanente",
  "Pago seguro por Hotmart",
  "Sorpresa final",
];
---

<Layout>

  <!-- Grain -->
  <div class="pointer-events-none fixed inset-0 z-[100] opacity-[0.025]" id="grain-oferta"></div>

  <!-- ======================================================================== -->
  <!-- HERO                                                                       -->
  <!-- ======================================================================== -->
  <section class="relative overflow-hidden pt-16 pb-12 md:pt-24 md:pb-16 px-6 md:px-10">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d0b06] to-[#151005]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80vw] h-[50vh] rounded-full bg-[#F3B23A] blur-[300px] opacity-[0.06] pointer-events-none"></div>

    <div class="max-w-[780px] mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2.5 bg-[#F3B23A]/10 border border-[#F3B23A]/25 backdrop-blur-sm py-2.5 px-6 rounded-full text-[12px] text-[#F3B23A] font-semibold tracking-[0.15em] uppercase mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#F3B23A] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#F3B23A]"></span>
        </span>
        Curso Introductorio
      </div>

      <h1 class="text-[28px] md:text-[46px] lg:text-[52px] font-bold leading-[1.1] mb-6">
        Introducción a los Principios del<br />
        <span class="text-[#F3B23A]">Vastu Shastra</span>
      </h1>
      <p class="text-[18px] md:text-[20px] text-white/60 font-light leading-[1.5] mb-4">
        Armonía en tu Hogar, Bienestar en tu Vida
      </p>
      <p class="text-white/40 text-[16px] md:text-[17px] leading-[1.7] font-light max-w-[580px] mx-auto mb-10">
        Aprendé a leer tu vida a través del espacio que habitás. A habitarlo conscientemente para generar equilibrio, armonía y bienestar real.
      </p>

      <a
        href={CTA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-2.5 px-10 py-5 rounded-full bg-[#FAF8F4] text-[#1a1710] border border-[#e8e2d4] font-bold text-[16px] transition-all duration-300 hover:shadow-[0_0_50px_rgba(243,178,58,0.35)] hover:-translate-y-0.5"
      >
        <span>Comprar ahora — USD 59</span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <p class="text-white/25 text-[12px] mt-4 flex items-center justify-center gap-2">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Pago 100% seguro · Acceso inmediato · Hasta 3 cuotas
      </p>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- MARQUEE BAR                                                                -->
  <!-- ======================================================================== -->
  <section class="relative border-y border-white/[0.06] bg-[#0d0b06] overflow-hidden py-4">
    <div class="marquee-track-oferta flex whitespace-nowrap">
      {[...MARQUEE_ITEMS, ...MARQUEE_ITEMS, ...MARQUEE_ITEMS].map((item) => (
        <span class="inline-flex items-center gap-4 px-8 text-[13px] font-medium tracking-[0.08em] uppercase text-white/40 shrink-0">
          <span class="w-1 h-1 rounded-full bg-[#F3B23A]/60"></span>
          {item}
        </span>
      ))}
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- VIDEO                                                                      -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-[#151005]"></div>
    <div class="max-w-[760px] mx-auto relative z-10">
      <div class="text-center mb-10">
        <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-4">Antes de empezar</span>
        <h2 class="text-[22px] md:text-[34px] font-bold leading-[1.15] mb-4">
          Esto va a cambiar cómo mirás<br class="hidden md:block" /> tu espacio para siempre
        </h2>
        <p class="text-white/40 text-[15px] font-light max-w-[460px] mx-auto">
          Porque cómo te sentís en un espacio no depende de lo que se ve, sino de la energía que lo sostiene.
        </p>
      </div>

      <div class="rounded-2xl overflow-hidden border border-white/[0.08] shadow-[0_20px_60px_rgba(0,0,0,0.4)]">
        <div class="relative w-full" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src="https://www.youtube-nocookie.com/embed/uBLdVkTTRNw?rel=0&modestbranding=1"
            title="Introducción al Vastu Shastra — Ivan Dacharry"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- VALUE PROP                                                                 -->
  <!-- ======================================================================== -->
  <section class="relative bg-[#FAF8F4] py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.3]" style="background-image: radial-gradient(circle, #c4b99a 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>
    <div class="max-w-[760px] mx-auto relative z-10 text-center">
      <span class="inline-block text-[12px] text-[#9a8a6a] font-semibold tracking-[0.2em] uppercase mb-6">Por qué este curso</span>
      <div class="space-y-6 text-[#4a4435] text-[17px] md:text-[18px] leading-[1.75] font-light">
        <p>Este es el primer paso para diseñar desde la energía hacia la materia.</p>
        <p>Tu Casa habla, y en este Curso vas a aprender a escucharla, interpretarla y transformarla.</p>
        <p class="font-semibold text-[#1a1710]">Vas a comprender que el Bienestar se diseña… y la Felicidad se construye.</p>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- MÓDULOS                                                                    -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#151005] to-[#0d0b06]"></div>
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle, #F3B23A 0.5px, transparent 0.5px); background-size: 28px 28px;"></div>

    <div class="max-w-[860px] mx-auto relative z-10">
      <div class="text-center mb-14">
        <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-4">Programa completo</span>
        <h2 class="text-[24px] md:text-[38px] font-bold leading-[1.12] mb-3">
          Mirá todo lo que vas a aprender
        </h2>
        <p class="text-white/40 text-[15px] font-light">4 módulos · ~2 horas de contenido · 3 bonus especiales</p>
      </div>

      <!-- Módulos -->
      <div class="space-y-4 mb-10">
        {MODULOS.map((m) => (
          <div class="group rounded-2xl border border-white/[0.07] bg-white/[0.02] p-6 md:p-7 hover:border-[#F3B23A]/20 hover:bg-white/[0.04] transition-all duration-400">
            <div class="flex gap-5 items-start">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] font-bold text-[13px]">{m.num}</span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <h3 class="font-bold text-[16px] md:text-[17px]">{m.title}</h3>
                  <span class="text-[11px] text-white/30 border border-white/10 rounded-full px-3 py-0.5">{m.dur}</span>
                </div>
                <p class="text-[#F3B23A]/70 text-[14px] font-semibold italic mb-2">{m.hook}</p>
                <p class="text-white/45 text-[14px] md:text-[15px] leading-[1.7] font-light">{m.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bonuses -->
      <div class="rounded-2xl border border-[#F3B23A]/15 p-6 md:p-8" style="background: linear-gradient(135deg, rgba(243,178,58,0.06) 0%, transparent 100%);">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-[#F3B23A] text-[20px]">✦</span>
          <h3 class="font-bold text-[17px] md:text-[19px]">Bonus incluidos</h3>
          <span class="text-[11px] text-[#F3B23A]/60 border border-[#F3B23A]/20 rounded-full px-3 py-0.5">3 bonus + sorpresa final</span>
        </div>
        <div class="space-y-4">
          {BONUS.map((b) => (
            <div class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] font-bold text-[11px]">{b.num}</span>
              <div>
                <p class="font-semibold text-[15px] mb-0.5">{b.title}</p>
                <p class="text-white/40 text-[13px] font-light">{b.desc}</p>
              </div>
            </div>
          ))}
          <div class="flex gap-4 items-start pt-2 border-t border-white/[0.06]">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] text-[14px]">★</span>
            <div>
              <p class="font-semibold text-[15px] text-[#F3B23A] mb-0.5">Sorpresa final</p>
              <p class="text-white/40 text-[13px] font-light">Para quienes lleguen hasta el final del curso.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- CTA MEDIA                                                                  -->
  <!-- ======================================================================== -->
  <section class="relative py-16 px-6 md:px-10 bg-[#0d0b06] border-y border-white/[0.05]">
    <div class="max-w-[600px] mx-auto text-center">
      <p class="text-white/40 text-[15px] font-light mb-6">¿Listo para empezar?</p>
      <a
        href={CTA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-2.5 px-10 py-5 rounded-full bg-[#FAF8F4] text-[#1a1710] border border-[#e8e2d4] font-bold text-[16px] transition-all duration-300 hover:shadow-[0_0_50px_rgba(243,178,58,0.35)] hover:-translate-y-0.5"
      >
        <span>Comprar ahora — USD 59</span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <p class="text-white/25 text-[12px] mt-4">Hasta 3 cuotas · Acceso permanente · Procesado por Hotmart</p>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- SOBRE IVAN                                                                 -->
  <!-- ======================================================================== -->
  <section class="relative bg-[#FAF8F4] py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.3]" style="background-image: radial-gradient(circle, #c4b99a 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

    <div class="max-w-[900px] mx-auto relative z-10">
      <div class="grid md:grid-cols-[320px_1fr] gap-10 md:gap-16 items-start">
        <div class="mx-auto md:mx-0">
          <div class="relative w-[280px] md:w-[320px] rounded-2xl overflow-hidden border border-[#e0d9c8] shadow-[0_20px_60px_rgba(0,0,0,0.08)]">
            <div class="absolute -inset-3 bg-gradient-to-br from-[#F3B23A]/15 to-transparent rounded-3xl blur-xl"></div>
            <img src="/images/ivan-about.png" alt="Ivan Dacharry" class="relative w-full h-full object-cover" />
          </div>
        </div>

        <div>
          <span class="inline-block text-[12px] text-[#9a8a6a] font-semibold tracking-[0.2em] uppercase mb-4">¿Quién soy?</span>
          <h2 class="text-[24px] md:text-[36px] font-bold text-[#1a1710] leading-[1.12] mb-6">
            Arq. Ivan <span class="text-[#b08a30]">Dacharry</span>
          </h2>
          <div class="space-y-4 text-[#4a4435] text-[15px] md:text-[16px] leading-[1.75] font-light">
            <p>Mi nombre es Iván Dacharry. Soy arquitecto formado en la Universidad de Buenos Aires (FADU). Durante años busqué respuestas afuera. Viví y trabajé en estudios internacionales en Italia, Turquía y Venezuela, persiguiendo experiencia, reconocimiento y crecimiento profesional. Pero dentro mío había una incoherencia muy grande.</p>
            <p>Volví a Argentina en un momento de profunda búsqueda personal. Y fue ahí cuando descubrí el Vastu Shastra, la Ciencia Ancestral que transformó por completo mi manera de entender el espacio… y mi propia vida.</p>
            <p>Hoy no solo diseño espacios. <strong class="font-semibold text-[#1a1710]">Formo personas</strong> que desean transformar su vida a través de su espacio, y profesionales que buscan ir más allá de la estética para diseñar bienestar, conciencia y conexión con la Naturaleza.</p>
            <p class="text-[#9a7a30] font-semibold italic">Porque no es lo mismo diseñar un espacio lindo, que diseñar un espacio para ser Feliz.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- TESTIMONIOS                                                                -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-[#151005]"></div>

    <div class="max-w-[900px] mx-auto relative z-10">
      <div class="text-center mb-14">
        <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-4">Testimonios</span>
        <h2 class="text-[24px] md:text-[38px] font-bold leading-[1.12]">
          ¿Qué opinan quienes ya tomaron el curso?
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {TESTIMONIOS.map((t) => (
          <div class="bg-white/[0.03] rounded-2xl p-6 md:p-7 border border-white/[0.07] hover:border-white/[0.12] transition-all duration-400">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-[#F3B23A]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-white/60 text-[14px] md:text-[15px] leading-[1.7] font-light mb-5">"{t.texto}"</p>
            <div class="flex items-center gap-3">
              <img class="w-10 h-10 object-cover rounded-full ring-2 ring-[#F3B23A]/20 ring-offset-2 ring-offset-[#151005]" src={t.image} alt={t.nombre} loading="lazy" />
              <div>
                <p class="font-bold text-[13px]">{t.nombre}</p>
                <p class="text-[11px] text-white/35">{t.rol}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- PRICING                                                                    -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d0b06] to-[#151005]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[#F3B23A] blur-[300px] opacity-[0.07]"></div>

    <div class="max-w-[520px] mx-auto relative z-10 text-center">
      <div class="w-12 h-[2px] bg-[#F3B23A]/30 mx-auto mb-8"></div>

      <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-6">Precio especial</span>

      <div class="rounded-2xl border border-[#F3B23A]/20 p-8 md:p-10 mb-8" style="background: linear-gradient(165deg, rgba(243,178,58,0.07) 0%, rgba(243,178,58,0.02) 60%, transparent 100%);">
