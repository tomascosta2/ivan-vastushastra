---
import Layout from "../layouts/Layout.astro";

const CTA_URL = "https://pay.hotmart.com/M104321896G?off=ruis2d2o&hotfeature=51";

const MODULOS = [
  {
    num: "01",
    title: "¿Qué es el Vastu Shastra?",
    deseo: "Finalmente vas a entender por qué algunos espacios te drenan y otros te elevan.",
    desc: "Descubrís qué es esta Ciencia Milenaria, de dónde surge y cómo la relación entre tu entorno, la Naturaleza y tu energía personal puede estar frenando —o potenciando— cada área de tu vida.",
  },
  {
    num: "02",
    title: "El Alma del Espacio — Vastu Purusha",
    deseo: "Vas a dejar de sentirte pesado o sin energía en tu propia casa.",
    desc: "Entendés el campo energético invisible que sostiene cada espacio. Por qué hay ambientes que te expanden y otros que te contraen. Y cómo hacer que tu hogar empiece a trabajar a tu favor.",
  },
  {
    num: "03",
    title: "El Mapa Energético de tu Hogar",
    deseo: "Vas a identificar exactamente qué bloqueos hay en tu espacio y qué área de tu vida afectan.",
    desc: "Aprendés a leer el lenguaje de los espacios. Los 5 elementos, las orientaciones, los desequilibrios concretos que impactan tu salud, tus finanzas, tus relaciones y tu trabajo.",
  },
  {
    num: "04",
    title: "Técnicas para Armonizar y Desbloquear",
    deseo: "Vas a salir con herramientas reales para empezar a transformar tu espacio hoy.",
    desc: "Conocés técnicas simples y aplicables —sin obras, sin gastos grandes— para limpiar la energía, armonizar ambientes y desbloquear lo que está frenado en tu vida.",
  },
];

const BONUS = [
  {
    num: "B1",
    title: "¿Cómo armar un Altar en mi Casa?",
    desc: "Creá un punto de energía consciente que potencie tu intención diaria.",
  },
  {
    num: "B2",
    title: "Líneas Hartmann — ¿Cómo detectarlas?",
    desc: "Identificá las zonas geopáticas que pueden estar afectando tu salud y descanso.",
  },
  {
    num: "B3",
    title: "Meditación de los 5 Elementos",
    desc: "Una práctica guiada para conectar tu energía con la de tu espacio.",
  },
];

const TESTIMONIOS = [
  {
    nombre: "Emilia Cuervo",
    rol: "Arquitecta",
    texto: "Me encantó el curso introductorio de Vastu Shastra! Iván es muy claro y didáctico con sus explicaciones. Ahora me encuentro realizando la formación completa porque necesitaba aprender en profundidad. Lo recomiendo 100%.",
    image: "/images/FERNANDA-MARCÓ-DE-PONT.jpeg",
  },
  {
    nombre: "María Belén López",
    rol: "Alumna del curso",
    texto: "Los temas tratados fueron más de los que esperaba. Me sorprendió y colmó mis expectativas respecto al contenido. Logra bajar a todos los niveles de entendimiento el contenido que busca transmitir.",
    image: "/images/LUCÍA-DELLEA.jpg",
  },
  {
    nombre: "Victoria Rodriguez",
    rol: "Alumna del curso",
    texto: "El curso espectacular, igual que la forma en que nos enseña Iván con palabras sencillas y ejemplos prácticos de aplicación. Aplicaré los conceptos en mi hogar y espero compartir mi experiencia.",
    image: "/images/CECILIA-RAMADORI.jpeg",
  },
  {
    nombre: "Natalia Rathmann",
    rol: "Alumna del curso",
    texto: "Siento que recibimos información de valor y muy completa para llevar a la práctica inmediatamente. Iván me transmitió claridad, precisión e inspiración. ¡Voy por la formación completa!",
    image: "/images/AGUSTINA-VANZULLI.jpg",
  },
];

const FAQS = [
  {
    pregunta: "¿Necesito tener conocimientos previos o ser Arquitecto?",
    respuesta: "No. El curso está diseñado desde cero para que cualquier persona pueda aprender los principios del Vastu Shastra, sin importar su profesión o experiencia previa.",
  },
  {
    pregunta: "¿Qué formato tienen las clases?",
    respuesta: "El curso es 100% online y grabado, para que lo hagas a tu ritmo. Incluye 4 módulos de aproximadamente 30 minutos cada uno, más 3 bonus especiales y una sorpresa final para quienes lleguen hasta el final.",
  },
  {
    pregunta: "¿Puedo trabajar como Consultor después del Curso?",
    respuesta: "Este es un curso introductorio que te brinda las bases esenciales del Vastu Shastra. Es el primer paso para comprender esta Ciencia Ancestral. Al finalizar, vas a recibir un regalo especial para continuar tu formación si sentís el llamado.",
  },
  {
    pregunta: "¿Cómo accedo al curso después de comprar?",
    respuesta: "Recibirás el acceso por email de forma inmediata. Podés ingresar desde cualquier dispositivo —computadora, smartphone o tablet— a través de la plataforma Hotmart.",
  },
  {
    pregunta: "¿Cómo compro y comienzo?",
    respuesta: "Hacé clic en 'Quiero mi acceso ahora', completá los datos y accedé inmediatamente. Lo único que necesitás es conexión a internet, un dispositivo y el deseo genuino de empezar a transformar tu espacio.",
  },
];
---

<Layout>

  <!-- Grain -->
  <div class="pointer-events-none fixed inset-0 z-[100] opacity-[0.025]" id="grain-oferta"></div>

  <!-- ======================================================================== -->
  <!-- VSL HERO                                                                   -->
  <!-- ======================================================================== -->
  <section class="relative overflow-hidden pt-14 pb-10 md:pt-20 md:pb-14 px-6 md:px-10">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d0b06] to-[#151005]"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80vw] h-[50vh] rounded-full bg-[#F3B23A] blur-[300px] opacity-[0.06] pointer-events-none"></div>

    <div class="max-w-[800px] mx-auto text-center relative z-10">

      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2.5 bg-[#F3B23A]/10 border border-[#F3B23A]/25 backdrop-blur-sm py-2.5 px-6 rounded-full text-[12px] text-[#F3B23A] font-semibold tracking-[0.15em] uppercase mb-8">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#F3B23A] opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#F3B23A]"></span>
        </span>
        Curso Introductorio · Solo USD 69
      </div>

      <!-- Headline -->
      <h1 class="text-[28px] md:text-[46px] lg:text-[54px] font-bold leading-[1.1] mb-5">
        Cuando la energía fluye en tu Hogar,<br class="hidden md:block" />
        <span class="text-[#F3B23A]">también fluye en tu vida.</span>
      </h1>

      <p class="text-white/50 text-[16px] md:text-[19px] font-light leading-[1.65] max-w-[620px] mx-auto mb-6">
        Descubrí la ciencia ancestral que transforma hogares caóticos en entornos de bienestar, claridad y abundancia — sin obras, sin gastos grandes.
      </p>

      <!-- VIDEO (VSL) -->
      <div class="rounded-2xl overflow-hidden border border-white/[0.08] shadow-[0_24px_80px_rgba(0,0,0,0.5)] mb-8">
        <div class="relative w-full" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src="https://www.youtube-nocookie.com/embed/uBLdVkTTRNw?rel=0&modestbranding=1"
            title="Introducción al Vastu Shastra — Ivan Dacharry"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <!-- CTA principal -->
      <a
        href={CTA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-2.5 px-10 py-5 rounded-full bg-[#FAF8F4] text-[#1a1710] border border-[#e8e2d4] font-bold text-[17px] transition-all duration-300 hover:shadow-[0_0_50px_rgba(243,178,58,0.4)] hover:-translate-y-0.5"
      >
        <span>Quiero mi acceso ahora — USD 69</span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <p class="text-white/25 text-[12px] mt-4 flex items-center justify-center gap-2">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        Pago 100% seguro · Acceso inmediato · Hasta 3 cuotas
      </p>

      <!-- Prueba social -->
      <div class="flex items-center justify-center gap-3 mt-8">
        <div class="flex -space-x-2.5">
          <img src="/images/FERNANDA-MARCÓ-DE-PONT.jpeg" alt="" class="w-9 h-9 rounded-full object-cover ring-2 ring-[#0d0b06]" />
          <img src="/images/LUCÍA-DELLEA.jpg" alt="" class="w-9 h-9 rounded-full object-cover ring-2 ring-[#0d0b06]" />
          <img src="/images/CECILIA-RAMADORI.jpeg" alt="" class="w-9 h-9 rounded-full object-cover ring-2 ring-[#0d0b06]" />
          <img src="/images/AGUSTINA-VANZULLI.jpg" alt="" class="w-9 h-9 rounded-full object-cover ring-2 ring-[#0d0b06]" />
        </div>
        <div class="text-left">
          <div class="flex gap-0.5 mb-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="w-3 h-3 text-[#F3B23A]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <p class="text-white/60 text-[13px] font-medium">+100 personas ya lo aplican</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- PAIN / BRIDGE                                                              -->
  <!-- ======================================================================== -->
  <section class="relative bg-[#FAF8F4] py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.3]" style="background-image: radial-gradient(circle, #c4b99a 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

    <div class="max-w-[720px] mx-auto relative z-10">
      <div class="space-y-8 text-[#1a1710] text-[18px] md:text-[20px] leading-[1.75] font-light">
        <p>Hay personas que cambian de trabajo, de pareja, de ciudad… y siguen sintiéndose igual.</p>
        <p>Estrés que no desaparece. Proyectos que no arrancan. Relaciones que no fluyen. Energía que se va sin saber adónde.</p>
        <p class="font-semibold">El Vastu Shastra dice que parte de la respuesta está en el espacio donde vivís.</p>
        <p class="text-[#4a4435]">Que tu hogar no es neutral. Que cada orientación, cada rincón, cada material tiene una influencia silenciosa sobre tu estado, tus decisiones y tus resultados.</p>
        <p class="text-[#9a7a30] font-semibold text-[20px] md:text-[22px]">
          Este curso te enseña a leerlo. A entenderlo. Y a cambiarlo.
        </p>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- MÓDULOS                                                                    -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#151005] to-[#0d0b06]"></div>
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle, #F3B23A 0.5px, transparent 0.5px); background-size: 28px 28px;"></div>

    <div class="max-w-[860px] mx-auto relative z-10">
      <div class="text-center mb-14">
        <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-4">Lo que vas a lograr</span>
        <h2 class="text-[24px] md:text-[38px] font-bold leading-[1.12] mb-3">
          4 clases que van a cambiar<br class="hidden md:block" /> cómo habitás tu mundo
        </h2>
        <p class="text-white/35 text-[14px] font-light">~30 minutos por clase · 100% online · A tu ritmo</p>
      </div>

      <div class="space-y-4 mb-10">
        {MODULOS.map((m) => (
          <div class="group rounded-2xl border border-white/[0.07] bg-white/[0.02] p-6 md:p-7 hover:border-[#F3B23A]/20 hover:bg-white/[0.04] transition-all duration-400">
            <div class="flex gap-5 items-start">
              <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] font-bold text-[13px]">{m.num}</span>
              <div class="flex-1 min-w-0">
                <p class="text-[#F3B23A]/80 text-[13px] font-semibold uppercase tracking-wide mb-1">{m.title}</p>
                <h3 class="font-bold text-[16px] md:text-[18px] mb-2 leading-snug">{m.deseo}</h3>
                <p class="text-white/40 text-[14px] md:text-[15px] leading-[1.7] font-light">{m.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bonuses -->
      <div class="rounded-2xl border border-[#F3B23A]/15 p-6 md:p-8" style="background: linear-gradient(135deg, rgba(243,178,58,0.06) 0%, transparent 100%);">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-[#F3B23A] text-[20px]">✦</span>
          <h3 class="font-bold text-[17px] md:text-[19px]">Bonus incluidos</h3>
          <span class="text-[11px] text-[#F3B23A]/60 border border-[#F3B23A]/20 rounded-full px-3 py-0.5">3 bonus + sorpresa final</span>
        </div>
        <div class="space-y-4">
          {BONUS.map((b) => (
            <div class="flex gap-4 items-start">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] font-bold text-[11px]">{b.num}</span>
              <div>
                <p class="font-semibold text-[15px] mb-0.5">{b.title}</p>
                <p class="text-white/40 text-[13px] font-light">{b.desc}</p>
              </div>
            </div>
          ))}
          <div class="flex gap-4 items-start pt-2 border-t border-white/[0.06]">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/20 flex items-center justify-center text-[#F3B23A] text-[14px]">★</span>
            <div>
              <p class="font-semibold text-[15px] text-[#F3B23A] mb-0.5">Sorpresa final</p>
              <p class="text-white/40 text-[13px] font-light">Para quienes lleguen hasta el final del curso.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- CTA INTERMEDIO                                                             -->
  <!-- ======================================================================== -->
  <section class="relative py-14 px-6 md:px-10 bg-[#0d0b06] border-y border-white/[0.05]">
    <div class="max-w-[580px] mx-auto text-center">
      <p class="text-white/50 text-[24px] md:text-[30px] font-light mb-2">Todo esto por <strong class="text-white font-bold">USD 69</strong> <span class="text-white/30 line-through text-[20px] md:text-[24px]">89</span>.</p>
      <p class="text-white/30 text-[14px] font-light mb-7">Menos que una consulta. Más que un cambio de ambiente.</p>
      <a
        href={CTA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center justify-center gap-2.5 px-10 py-5 rounded-full bg-[#FAF8F4] text-[#1a1710] border border-[#e8e2d4] font-bold text-[16px] transition-all duration-300 hover:shadow-[0_0_50px_rgba(243,178,58,0.35)] hover:-translate-y-0.5"
      >
        <span>Quiero mi acceso ahora</span>
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- SOBRE IVAN                                                                 -->
  <!-- ======================================================================== -->
  <section class="relative bg-[#FAF8F4] py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.3]" style="background-image: radial-gradient(circle, #c4b99a 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

    <div class="max-w-[900px] mx-auto relative z-10">
      <div class="grid md:grid-cols-[300px_1fr] gap-10 md:gap-16 items-start">
        <div class="mx-auto md:mx-0">
          <div class="relative w-[260px] md:w-[300px] rounded-2xl overflow-hidden border border-[#e0d9c8] shadow-[0_20px_60px_rgba(0,0,0,0.08)]">
            <div class="absolute -inset-3 bg-gradient-to-br from-[#F3B23A]/15 to-transparent rounded-3xl blur-xl"></div>
            <img src="/images/ivan-about.png" alt="Ivan Dacharry" class="relative w-full h-full object-cover" />
          </div>
        </div>

        <div>
          <span class="inline-block text-[12px] text-[#9a8a6a] font-semibold tracking-[0.2em] uppercase mb-4">Tu guía en este camino</span>
          <h2 class="text-[24px] md:text-[36px] font-bold text-[#1a1710] leading-[1.12] mb-6">
            Arq. Ivan <span class="text-[#b08a30]">Dacharry</span>
          </h2>
          <div class="space-y-4 text-[#4a4435] text-[15px] md:text-[16px] leading-[1.75] font-light">
            <p>Arquitecto formado en la UBA. Viví y trabajé en estudios internacionales en Italia, Turquía y Venezuela buscando lo que no estaba afuera.</p>
            <p>Cuando descubrí el Vastu Shastra, entendí por qué. Esta ciencia no solo transformó mi arquitectura — transformó mi vida.</p>
            <p>Hoy formo personas que quieren dejar de luchar contra su entorno y empezar a que el entorno trabaje para ellas.</p>
            <p class="text-[#9a7a30] font-semibold italic text-[17px]">"No es lo mismo diseñar un espacio lindo, que diseñar un espacio para ser Feliz."</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- TESTIMONIOS                                                                -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-[#151005]"></div>

    <div class="max-w-[900px] mx-auto relative z-10">
      <div class="text-center mb-14">
        <span class="inline-block text-[12px] text-[#F3B23A]/70 font-semibold tracking-[0.2em] uppercase mb-4">Resultados reales</span>
        <h2 class="text-[24px] md:text-[38px] font-bold leading-[1.12]">
          Lo que dicen quienes ya<br class="hidden md:block" /> dieron el primer paso
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {TESTIMONIOS.map((t) => (
          <div class="bg-white/[0.03] rounded-2xl p-6 md:p-7 border border-white/[0.07] hover:border-white/[0.12] transition-all duration-400">
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 text-[#F3B23A]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-white/60 text-[14px] md:text-[15px] leading-[1.7] font-light mb-5">"{t.texto}"</p>
            <div class="flex items-center gap-3">
              <img class="w-10 h-10 object-cover rounded-full ring-2 ring-[#F3B23A]/20 ring-offset-2 ring-offset-[#151005]" src={t.image} alt={t.nombre} loading="lazy" />
              <div>
                <p class="font-bold text-[13px]">{t.nombre}</p>
                <p class="text-[11px] text-white/35">{t.rol}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- PRICING                                                                    -->
  <!-- ======================================================================== -->
  <section class="relative py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0d0b06] to-[#151005]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-[#F3B23A] blur-[300px] opacity-[0.07]"></div>

    <div class="max-w-[520px] mx-auto relative z-10 text-center">
      <div class="w-12 h-[2px] bg-[#F3B23A]/30 mx-auto mb-10"></div>

      <h2 class="text-[22px] md:text-[32px] font-bold leading-[1.2] mb-3">
        Cuando ordenás la energía de tu espacio,<br class="hidden md:block" />
        <span class="text-[#F3B23A]">la vida empieza a ordenarse sola.</span>
      </h2>
      <p class="text-white/40 text-[15px] font-light mb-10">Este curso es el primer paso. Y cuesta menos que lo que gastás en una salida.</p>

      <div class="rounded-2xl border border-[#F3B23A]/20 p-8 md:p-10 mb-8" style="background: linear-gradient(165deg, rgba(243,178,58,0.07) 0%, rgba(243,178,58,0.02) 60%, transparent 100%);">
        <div class="flex justify-center mb-4">
          <span class="inline-flex items-center gap-1.5 bg-[#F3B23A]/15 border border-[#F3B23A]/30 text-[#F3B23A] text-[12px] font-semibold tracking-[0.1em] uppercase px-4 py-1.5 rounded-full">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            22% OFF — Antes USD 89
          </span>
        </div>
        <div class="flex items-end justify-center gap-3 mb-2">
          <span class="text-white/40 text-[18px] font-medium self-start mt-3">USD</span>
          <span class="text-[72px] font-bold leading-none tracking-tight text-white">69</span>
          <span class="text-white/25 text-[20px] line-through self-end mb-2">89</span>
        </div>
        <p class="text-white/30 text-[13px] mb-8">Pago único · Acceso permanente · Hasta 3 cuotas</p>

        <ul class="text-left space-y-3 mb-8">
          {["4 clases completas (~2 horas)", "3 bonus especiales", "Sorpresa final exclusiva", "Acceso desde cualquier dispositivo", "Sin vencimiento"].map((item) => (
            <li class="flex items-center gap-3 text-[14px] text-white/55">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-[#F3B23A]/10 border border-[#F3B23A]/25 flex items-center justify-center">
                <svg class="w-2.5 h-2.5 text-[#F3B23A]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </span>
              {item}
            </li>
          ))}
        </ul>

        <a
          href={CTA_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group block w-full text-center py-5 rounded-full bg-[#FAF8F4] text-[#1a1710] border border-[#e8e2d4] font-bold text-[16px] transition-all duration-300 hover:shadow-[0_0_50px_rgba(243,178,58,0.35)] hover:-translate-y-0.5"
        >
          Quiero mi acceso ahora →
        </a>
        <p class="text-white/25 text-[12px] mt-4 flex items-center justify-center gap-2">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Pago 100% seguro · Acceso inmediato
        </p>
      </div>

      <div class="w-12 h-[2px] bg-[#F3B23A]/30 mx-auto"></div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- FAQS                                                                       -->
  <!-- ======================================================================== -->
  <section class="relative bg-[#FAF8F4] py-20 md:py-28 px-6 md:px-10 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.3]" style="background-image: radial-gradient(circle, #c4b99a 0.5px, transparent 0.5px); background-size: 24px 24px;"></div>

    <div class="max-w-[720px] mx-auto relative z-10">
      <div class="text-center mb-14">
        <span class="inline-block text-[12px] text-[#9a8a6a] font-semibold tracking-[0.2em] uppercase mb-4">Preguntas frecuentes</span>
        <h2 class="text-[24px] md:text-[38px] font-bold text-[#1a1710] leading-[1.12]">¿Tenés dudas?</h2>
      </div>

      <div>
        {FAQS.map((item, index) => (
          <div class="oferta-faq-item group border-b border-[#d4cdb8]/60 last:border-b-0" data-index={index}>
            <button class="oferta-faq-question w-full text-left py-6 flex justify-between items-center gap-6 cursor-pointer">
              <h3 class="font-semibold text-[15px] md:text-[17px] text-[#1a1710] group-hover:text-[#9a7a30] transition-colors">{item.pregunta}</h3>
              <span class="oferta-faq-icon flex-shrink-0 w-8 h-8 rounded-full border border-[#d4cdb8] flex items-center justify-center transition-all duration-300 group-hover:border-[#c4a55a] group-hover:bg-[#F3B23A]/5">
                <svg class="w-3.5 h-3.5 text-[#9a8a6a] transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              </span>
            </button>
            <div class="oferta-faq-answer overflow-hidden transition-all duration-500 max-h-0">
              <p class="text-[#6a6354] text-[14px] md:text-[15px] pb-6 leading-[1.7] font-light">{item.respuesta}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================================================================== -->
  <!-- FOOTER                                                                     -->
  <!-- ======================================================================== -->
  <footer class="relative py-10 px-6 md:px-10 border-t border-white/[0.06] bg-[#0d0b06]">
    <div class="max-w-[900px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/25 text-[13px] font-light">© {new Date().getFullYear()} Ivan Dacharry · Vastu Shastra</p>
      <a href="https://www.instagram.com/ivan.dacharry/" target="_blank" rel="noopener" class="text-white/30 hover:text-[#F3B23A] transition-colors">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
    </div>
  </footer>

  <script is:inline>
    (function () {
      document.querySelectorAll(".oferta-faq-item").forEach(function (item) {
        var btn = item.querySelector(".oferta-faq-question");
        var answer = item.querySelector(".oferta-faq-answer");
        btn.addEventListener("click", function () {
          var isOpen = item.classList.contains("open");
          document.querySelectorAll(".oferta-faq-item.open").forEach(function (o) {
            o.classList.remove("open");
            o.querySelector(".oferta-faq-answer").style.maxHeight = "0";
          });
          if (!isOpen) {
            item.classList.add("open");
            answer.style.maxHeight = answer.scrollHeight + "px";
          }
        });
      });
    })();
  </script>

  <script is:inline>
    window.addEventListener("load", function () {
      if (typeof fbq !== "undefined") fbq("track", "PageView");
    });
  </script>

</Layout>

<style>
  #grain-oferta {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 180px 180px;
  }

  .oferta-faq-item.open .oferta-faq-icon svg {
    transform: rotate(45deg);
  }
  .oferta-faq-item.open .oferta-faq-icon {
    background-color: rgba(243, 178, 58, 0.1);
    border-color: #c4a55a;
  }
</style>
