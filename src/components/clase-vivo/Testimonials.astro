---
interface Testimonial {
  name: string;
  role?: string;
  photo: string;
  quote: string;
}

const testimonials: Testimonial[] = [
  {
    name: "Emilia Cuervo",
    photo: "/images/EMILIA-CUERVO.png",
    quote:
      "Me encantó el curso introductorio de Vastu Shastra! Iván es muy claro y didáctico con sus explicaciones. Ahora me encuentro realizando la formación ya que necesitaba aprender en profundidad este tema que me resulta muy interesante y aplicable en el día a día para poder equilibrar tanto las energías de los ambientes en los cuales habito como en mi propio ser. Soy arquitecta y va a ser una gran herramienta para fusionar con mi profesión. Lo recomiendo 100%.",
  },
  {
    name: "María Belén López",
    photo: "/images/MARIA-BELEN-LOPEZ.png",
    quote:
      "Me sentí muy a gusto durante la clase. Los temas tratados fueron más de los que esperaba, me sorprendió y colmó mis expectativas respecto al contenido, teniendo en cuenta la duración del curso. Respecto a la forma de dar la clase, sentí que fue claro y coherente al explicar y acorde a su modo en las redes sociales donde lo conocí a Iván. Logra bajar a todos los niveles de entendimiento el contenido que busca transmitir. Me agradan su simpleza y sus modos.",
  },
  {
    name: "Victoria Rodriguez",
    photo: "/images/VICTORIA-RODRIGUEZ.png",
    quote:
      "El curso espectacular, igual que la forma en que nos enseña Iván con palabras sencillas, ejemplos prácticos de aplicación. Aplicaré los conceptos en mi hogar y espero compartir mi experiencia.",
  },
  {
    name: "Natalia Rathmann",
    photo: "/images/NATALIA-RATHMANN.png",
    quote:
      "Me encantó el curso; siento que recibimos información de valor y muy completa para llevar a la práctica inmediatamente. Iván me trasmitió claridad, precisión e inspiración. Voy por la formación! Muchas gracias!",
  },
];
---

<section class="py-16 md:py-24 px-4 bg-white/[0.02] border-y border-white/5">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-10 md:mb-14">
      <span class="text-[#F3B23A] text-[12px] font-semibold tracking-[0.2em] uppercase">
        Lo que dicen
      </span>
      <h2 class="text-[28px] md:text-[40px] font-bold mt-3 leading-[1.15] tracking-[-0.02em]">
        Resultados reales, no “qué linda clase”
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4 md:gap-5">
      {testimonials.map((t) => (
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5 md:p-6">
          <div class="flex items-center gap-1 mb-3">
            {Array.from({ length: 5 }).map(() => (
              <svg class="size-4 text-[#F3B23A]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
              </svg>
            ))}
          </div>
          <p class="text-white/85 text-[15px] md:text-[16px] leading-[1.65]">
            “{t.quote}”
          </p>
          <div class="flex items-center gap-3 mt-5 pt-5 border-t border-white/10">
            <img
              src={t.photo}
              alt={t.name}
              class="size-11 rounded-full object-cover border border-white/10"
            />
            <div>
              <p class="font-semibold text-[14px]">{t.name}</p>
              {t.role && <p class="text-[12px] text-white/50">{t.role}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
