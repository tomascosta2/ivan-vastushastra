---
import {
  PRECIO_LABEL,
  PRECIO_USD,
  ANCHOR_USD,
  CUOTAS,
  HOTMART_URL,
} from "../../data/clase-vivo";

const items = [
  { label: "Clase en vivo de 2 horas con Iván Dacharry", value: "USD 120" },
  { label: "Espacio Q&A en vivo (preguntas dirigidas a tu caso)", value: "USD 60" },
  { label: "Grabación completa de la clase + bonus", value: "USD 40" },
  { label: "Bonus #1 — Cómo armar tu altar (PDF)", value: "USD 25" },
  { label: "Bonus #2 — Detección de líneas Hartmann", value: "USD 35" },
  { label: "Bonus #3 — Meditación 5 elementos (audio)", value: "USD 20" },
  { label: "Bonus #4 — Sorpresa exclusiva (revelado en vivo)", value: "USD 50" },
];

const total = items.reduce((acc, i) => acc + parseInt(i.value.replace("USD ", ""), 10), 0);
---

<section class="py-16 md:py-24 px-4">
  <div class="max-w-[820px] mx-auto">
    <div class="text-center mb-10 md:mb-12">
      <span class="text-[#F3B23A] text-[12px] font-semibold tracking-[0.2em] uppercase">
        Por qué cuesta lo que cuesta
      </span>
      <h2 class="text-[28px] md:text-[40px] font-bold mt-3 leading-[1.15] tracking-[-0.02em]">
        La formación que hice en Estados Unidos arranca en
        <span class="text-[#F3B23A]">USD {ANCHOR_USD.toLocaleString("en-US")}</span>.
        <br class="hidden md:block" />
        Esto es <span class="text-[#F3B23A]">{PRECIO_LABEL}</span>.
      </h2>
      <p class="text-white/60 text-[15px] md:text-[17px] mt-4 max-w-[600px] mx-auto leading-[1.6]">
        Hago esta clase como puerta de entrada — para que entiendas qué es Vastu
        sin que te cueste lo mismo que la formación completa. Si después querés
        profundizar, te muestro cómo al final de la clase.
      </p>
    </div>

    <div class="rounded-2xl border border-[#F3B23A]/30 bg-gradient-to-br from-[#F3B23A]/[0.06] to-transparent p-6 md:p-10">
      <p class="text-[11px] uppercase tracking-[0.2em] text-white/40 mb-4">
        Lo que recibís
      </p>
      <ul class="space-y-3">
        {items.map((item) => (
          <li class="flex items-start justify-between gap-4 pb-3 border-b border-white/[0.06] last:border-0 last:pb-0">
            <div class="flex items-start gap-2.5">
              <svg class="size-4 text-[#F3B23A] shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-[14px] md:text-[15px] text-white/85">{item.label}</span>
            </div>
            <span class="text-[13px] md:text-[14px] text-white/40 line-through tabular-nums shrink-0">
              {item.value}
            </span>
          </li>
        ))}
      </ul>

      <div class="mt-6 pt-6 border-t border-white/10 flex items-center justify-between">
        <span class="text-white/60 text-[14px] md:text-[15px]">Valor total</span>
        <span class="text-white/40 text-[16px] md:text-[18px] line-through tabular-nums">
          USD {total}
        </span>
      </div>
      <div class="flex items-end justify-between mt-2">
        <span class="text-white text-[15px] md:text-[17px] font-semibold">
          Tu inversión hoy
        </span>
        <span class="text-[#F3B23A] text-[36px] md:text-[48px] font-black tabular-nums leading-none">
          {PRECIO_LABEL}
        </span>
      </div>

      <a
        href={HOTMART_URL}
        class="block mt-8 w-full text-center bg-[#F3B23A] hover:bg-[#ffc34c] text-[#1a1106] font-bold text-[17px] md:text-[19px] py-4 md:py-5 rounded-full transition-all hover:-translate-y-0.5 hover:shadow-[0_20px_60px_-15px_rgba(243,178,58,0.6)]"
      >
        Reservar mi lugar — {PRECIO_LABEL}
      </a>
      <p class="text-center text-white/50 text-[12px] mt-3">
        {CUOTAS} · Acceso inmediato + grabación · Pago seguro vía Hotmart
      </p>
    </div>
  </div>
</section>
