---
import {
  HOTMART_URL,
  PRECIO_LABEL,
  FECHAS,
} from "../../data/clase-vivo";
---

<div
  id="cv-sticky"
  class="fixed left-0 right-0 bottom-0 z-50 px-3 pb-3 sm:px-4 sm:pb-4 pointer-events-none transition-all duration-300 opacity-0 translate-y-3"
>
  <div class="max-w-[640px] mx-auto bg-[#1a1106]/95 backdrop-blur-md border border-[#F3B23A]/30 rounded-xl shadow-[0_-10px_40px_-10px_rgba(0,0,0,0.6)] p-3 sm:p-3.5 flex items-center gap-3 pointer-events-auto">
    <div class="hidden sm:flex flex-col min-w-0 flex-1">
      <span class="text-[11px] uppercase tracking-wide text-white/45">
        Próxima clase
      </span>
      <span class="text-[14px] font-semibold text-white truncate">
        {FECHAS[0].label}
      </span>
    </div>
    <div class="flex sm:hidden flex-col min-w-0 flex-1">
      <span class="text-[12px] font-semibold text-white truncate">
        Clase en vivo · {PRECIO_LABEL}
      </span>
      <span class="text-[10.5px] text-white/50 truncate">
        {FECHAS[0].label}
      </span>
    </div>
    <a
      href={HOTMART_URL}
      class="shrink-0 bg-[#F3B23A] hover:bg-[#ffc34c] text-[#1a1106] font-bold text-[13px] sm:text-[14px] px-4 sm:px-6 py-2.5 sm:py-3 rounded-full transition-all hover:-translate-y-0.5 whitespace-nowrap"
    >
      Reservar — <span class="hidden sm:inline">{PRECIO_LABEL}</span><span class="sm:hidden">USD 65</span>
    </a>
  </div>
</div>

<script is:inline>
  (function () {
    const sticky = document.getElementById("cv-sticky");
    if (!sticky) return;

    const SHOW_AFTER_PX = 600;
    let visible = false;

    function update() {
      const shouldShow = window.scrollY > SHOW_AFTER_PX;
      if (shouldShow && !visible) {
        sticky.classList.remove("opacity-0", "translate-y-3");
        sticky.classList.add("opacity-100", "translate-y-0");
        visible = true;
      } else if (!shouldShow && visible) {
        sticky.classList.remove("opacity-100", "translate-y-0");
        sticky.classList.add("opacity-0", "translate-y-3");
        visible = false;
      }
    }

    window.addEventListener("scroll", update, { passive: true });
    update();
  })();
</script>
