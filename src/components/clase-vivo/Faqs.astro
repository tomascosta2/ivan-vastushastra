---
const faqs: { q: string; a: string[] }[] = [
  {
    q: "¿Necesito conocimientos previos sobre Vastu Shastra?",
    a: [
      "No.",
      "Esta experiencia está pensada como una introducción clara y accesible al Vastu Shastra, tanto para arquitectos y diseñadores como para cualquier persona interesada en comprender el impacto del Espacio sobre nuestra vida.",
    ],
  },
  {
    q: "¿Qué pasa si no puedo conectarme en vivo?",
    a: [
      "La clase queda grabada y vas a poder verla después, a tu ritmo y sin límite de tiempo.",
      "De todas formas, participar en vivo te permite vivir la experiencia completa y formar parte del espacio de preguntas al final de la clase.",
    ],
  },
  {
    q: "¿Con esta clase ya soy un experto en Vastu Shastra?",
    a: [
      "No.",
      "Esta experiencia es una puerta de entrada al Vastu Shastra y a una nueva forma de comprender el Espacio.",
      "Si después querés profundizar profesionalmente, al final de la clase vas a conocer las opciones de formación avanzada.",
    ],
  },
  {
    q: "¿Cuándo y cómo puedo participar de la experiencia?",
    a: [
      "La experiencia se realiza en vivo a través de Zoom el miércoles 27 a las 19:30 hs (Argentina) y el sábado 30 a las 10:00 hs (Argentina).",
      "Una vez que completes tu inscripción e ingreses al grupo de WhatsApp, se te enviará toda la información para que puedas elegir la fecha y horario en la que desees participar. Y si lo deseás, también podés asistir a ambos encuentros.",
    ],
  },
];
---

<section class="py-16 md:py-24 px-4">
  <div class="max-w-[760px] mx-auto">
    <div class="text-center mb-10 md:mb-14">
      <span class="text-[#F3B23A] text-[12px] font-semibold tracking-[0.2em] uppercase">
        Preguntas frecuentes
      </span>
      <h2 class="text-[28px] md:text-[40px] font-bold mt-3 leading-[1.15] tracking-[-0.02em]">
        Lo que preguntan antes de anotarse
      </h2>
    </div>

    <div class="space-y-3">
      {faqs.map((f) => (
        <details class="group rounded-xl border border-white/10 bg-white/[0.03] hover:border-[#F3B23A]/30 transition-colors">
          <summary class="cursor-pointer list-none p-5 md:p-6 flex items-start justify-between gap-4">
            <span class="font-semibold text-[15px] md:text-[17px] leading-snug">
              {f.q}
            </span>
            <svg class="size-5 text-[#F3B23A]/70 shrink-0 mt-0.5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5 md:px-6 md:pb-6 text-white/70 text-[14px] md:text-[15px] leading-[1.7] space-y-2">
            {f.a.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
